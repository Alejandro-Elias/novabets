{
  "name": "novabeats",
  "version": "1.2.4",
  "description": "Reproductor de música local desarrollado con Electron.",
  "main": "./src/main.js",
  "type": "commonjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "keywords": [],
  "author": {
    "name": "Alejandro Elias",
    "email": "alejandroelias@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "animate.css": "^4.1.1",
    "audiomotion-analyzer": "^4.5.4",
    "music-metadata": "^11.12.3"
  },
  "build": {
    "appId": "io.github.alejandroelias.NovaBeats",
    "productName": "NovaBeats",

    "electronVersion": "42.1.0",

    "electronDownload": {
      "cache": "/run/build/novabeats/electron-cache",
      "mirror": "https://github.com/electron/electron/releases/download/"
    },

    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "AudioVideo",
      "icon": "build"
    },

    "win": {
      "icon": "build/icon.ico"
    }
  }
}