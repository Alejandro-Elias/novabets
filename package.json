    "name": "Alejandro Elias",
    "email": "alejandroelias@gmail.com"
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
