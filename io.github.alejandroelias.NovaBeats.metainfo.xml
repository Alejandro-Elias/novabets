<component type="desktop-application">
  <id>io.github.alejandroelias.NovaBeats</id>

  <name>NovaBeats</name>
  <summary>Local music player</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="io.github.alejandroelias">
    <name>Alejandro Elias</name>
  </developer>

  <launchable type="desktop-id">
    io.github.alejandroelias.NovaBeats.desktop
  </launchable>

  <description>
    <p>
      NovaBeats is a local music player built with Electron. It provides a clean
      and intuitive interface to organize and play your music collection.
    </p>

    <p>Main features:</p>

    <ul>
      <li>Play local audio files.</li>
      <li>Create and manage playlists.</li>
      <li>Simple and lightweight interface.</li>
      <li>Fast access to your music library.</li>
    </ul>
  </description>

  <categories>
    <category>AudioVideo</category>
    <category>Music</category>
  </categories>

